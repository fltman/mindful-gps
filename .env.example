# Ruttmotor. Lokalt: självhostad Valhalla i Docker (ingen nyckel, inga kvoter).
VALHALLA_URL=http://localhost:8002
# Sätts bara om vi byter till en hostad Valhalla (t.ex. Stadia). Tom = självhostad.
VALHALLA_API_KEY=

DATABASE_URL=postgres://mindful:mindful@localhost:5435/mindful
PORT=8161
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Kontaktuppgift i User-Agent mot Overpass. Fair use kräver att den som frågar går att nå.
# Behövs bara om du hämtar vägdata ur Overpass — seedar du ur den lokala OSM-extrakten
# (vilket är standard) rörs den aldrig.
OVERPASS_CONTACT=din@epost.se

# ── AI-berättelser om sevärdheter (TILLVAL) ─────────────────────────────────
# Utan de här nycklarna funkar allt annat; en tryckt sevärdhet svarar då "inte påslaget".
#
# Texten: ett grundat OpenRouter-anrop. Sök-modellen både söker och skriver, och
# returnerar källorna vi visar. Perplexity Sonar är förval — snabb och sök-native.
# Billigare alternativ: anthropic/claude-haiku-4.5:online (behåll :online, annars
# tystnar källorna).
OPENROUTER_API_KEY=
OPENROUTER_STORY_MODEL=perplexity/sonar-pro-search

# Uppläsningen: ElevenLabs. Rösten och modellen går att byta.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=Mml2TPQDyjmb9MxQdllJ
ELEVENLABS_MODEL=eleven_v3
